<?xml version="1.0" encoding="utf-8"?>
<!--
    SCREEN 4 — Critical Alert Overlay
    Activity: AlertActivity.java (or use as a Dialog layout)
    Orientation: Landscape (inherits from Dashboard)
    Notes:
      - Use as a full-screen Dialog launched from DashboardActivity
      - Pass alert title, value, unit, threshold via Intent extras
      - Dismiss returns to Dashboard; data stream continues uninterrupted
      - Consider android:windowBackground="#CC000000" for semi-transparent overlay effect
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC0A0C0F"
    android:padding="32dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/card_alert"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#4A0F0F"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        android:layout_marginStart="80dp"
        android:layout_marginEnd="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="28dp">

            <!-- Warning icon -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠"
                android:textColor="#FF3B3B"
                android:textSize="40sp"
                android:layout_marginBottom="12dp"/>

            <!-- Alert type -->
            <TextView
                android:id="@+id/tv_alert_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FC Temp Critical"
                android:textColor="#FCA5A5"
                android:textSize="22sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="8dp"/>

            <!-- Alert value — large -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:layout_marginBottom="6dp">

                <TextView
                    android:id="@+id/tv_alert_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="81"
                    android:textColor="#FFFFFF"
                    android:textSize="52sp"
                    android:fontFamily="sans-serif-medium"
                    android:includeFontPadding="false"/>

                <TextView
                    android:id="@+id/tv_alert_unit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" °C"
                    android:textColor="#FCA5A5"
                    android:textSize="22sp"
                    android:layout_marginBottom="8dp"/>

            </LinearLayout>

            <!-- Threshold + instruction -->
            <TextView
                android:id="@+id/tv_alert_threshold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Limit: 70°C · Reduce power immediately"
                android:textColor="#F87171"
                android:textSize="13sp"
                android:layout_marginBottom="24dp"/>

            <!-- Dismiss button -->
            <Button
                android:id="@+id/btn_alert_acknowledge"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Acknowledge · Back to Dashboard"
                android:textColor="#FCA5A5"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_btn_alert_dismiss"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:layout_marginBottom="12dp"/>

            <!-- Stream note -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Data stream continues in background"
                android:textColor="#4A0F0F"
                android:textSize="10sp"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
