<?xml version="1.0" encoding="utf-8"?>
<!--
    SCREEN 1 — Car Select
    Activity: CarSelectActivity.java
    Orientation: Portrait
    Notes: Driver picks Thaiger 7 or Bengalo before connecting.
           Selected car card gets highlighted border.
           Connect button triggers BluetoothConnectActivity.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0C0F"
    android:padding="24dp">

    <!-- Team logo / title -->
    <TextView
        android:id="@+id/tv_team_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="THAIGER H2 RACING"
        android:textColor="#3D6FFF"
        android:textSize="11sp"
        android:letterSpacing="0.18"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"/>

    <TextView
        android:id="@+id/tv_select_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Vehicle"
        android:textColor="#E8EDF2"
        android:textSize="28sp"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintTop_toBottomOf="@id/tv_team_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"/>

    <!-- Divider -->
    <View
        android:id="@+id/divider_title"
        android:layout_width="48dp"
        android:layout_height="2dp"
        android:background="#3D6FFF"
        app:layout_constraintTop_toBottomOf="@id/tv_select_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"/>

    <!-- Car cards row -->
    <LinearLayout
        android:id="@+id/ll_car_cards"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/divider_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Thaiger 7 card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_thaiger7"
            android:layout_width="0dp"
            android:layout_height="180dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            app:cardBackgroundColor="#111418"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡"
                    android:textSize="32sp"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thaiger 7"
                    android:textColor="#E8EDF2"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Prototype"
                    android:textColor="#7A8A99"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="H₂ Fuel Cell"
                    android:textColor="#3D6FFF"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Bengalo card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_bengalo"
            android:layout_width="0dp"
            android:layout_height="180dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            app:cardBackgroundColor="#111418"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🚗"
                    android:textSize="32sp"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bengalo"
                    android:textColor="#E8EDF2"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Urban Concept"
                    android:textColor="#7A8A99"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="H₂ Fuel Cell"
                    android:textColor="#3D6FFF"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- Selected car label -->
    <TextView
        android:id="@+id/tv_selected_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Thaiger 7 selected"
        android:textColor="#3D6FFF"
        android:textSize="12sp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/ll_car_cards"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Connect button -->
    <Button
        android:id="@+id/btn_connect"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:text="Connect to Thaiger 7"
        android:textColor="#93C5FD"
        android:textSize="15sp"
        android:fontFamily="sans-serif-medium"
        android:background="@drawable/bg_btn_primary"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tv_selected_hint"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Settings link -->
    <TextView
        android:id="@+id/tv_settings"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚙ Settings"
        android:textColor="#3D4F60"
        android:textSize="12sp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/btn_connect"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Version footer -->
    <TextView
        android:id="@+id/tv_version"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0.0 · HS Stralsund"
        android:textColor="#1E2530"
        android:textSize="11sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
