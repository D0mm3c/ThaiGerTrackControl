<?xml version="1.0" encoding="utf-8"?>
<!--
    SCREEN 2 — Bluetooth Connecting
    Activity: ConnectingActivity.java
    Orientation: Portrait
    Notes: Shown while BluetoothSocket is being established.
           Animate the progress ring via ObjectAnimator in Java.
           Auto-advances to DashboardActivity on successful connect.
           "Cancel" returns to CarSelectActivity.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0C0F"
    android:padding="24dp">

    <!-- Spinning progress ring -->
    <ProgressBar
        android:id="@+id/progress_connecting"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:indeterminate="true"
        android:indeterminateTint="#3D6FFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.38"/>

    <TextView
        android:id="@+id/tv_connecting_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Connecting to Thaiger 7…"
        android:textColor="#E8EDF2"
        android:textSize="20sp"
        android:fontFamily="sans-serif-medium"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/progress_connecting"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tv_connecting_device"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Looking for ESP32-THR7 via Bluetooth"
        android:textColor="#3D4F60"
        android:textSize="13sp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_connecting_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Reconnect note -->
    <TextView
        android:id="@+id/tv_reconnect_note"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Auto-reconnects if signal is lost during a run"
        android:textColor="#1E2530"
        android:textSize="11sp"
        android:gravity="center"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/tv_connecting_device"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Action buttons -->
    <LinearLayout
        android:id="@+id/ll_connect_actions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="36dp"
        app:layout_constraintTop_toBottomOf="@id/tv_reconnect_note"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btn_cancel"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Cancel"
            android:textColor="#7A8A99"
            android:textSize="13sp"
            android:background="@drawable/bg_btn_secondary"
            android:layout_marginEnd="12dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"/>

        <Button
            android:id="@+id/btn_pair_new"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Pair New Device"
            android:textColor="#7A8A99"
            android:textSize="13sp"
            android:background="@drawable/bg_btn_secondary"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
