<?xml version="1.0" encoding="utf-8"?>
<!--
    SCREEN 6 — Settings
    Activity: SettingsActivity.java
    Orientation: Portrait
    Notes:
      - Accessible from CarSelectActivity via gear icon
      - All values persisted via SharedPreferences
      - sw_wake_lock: acquire/release PowerManager.WakeLock
      - sw_vibrate: Vibrator.vibrate() on alert events
      - sw_alert_sound: AudioManager / MediaPlayer short tone
      - tv_update_rate_value / tv_fc_threshold_value: open NumberPicker dialogs
      - Thresholds stored per-car key: "fc_temp_threshold_thaiger7", "fc_temp_threshold_bengalo"
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0C0F">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:id="@+id/ll_settings_header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tv_settings_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← "
                android:textColor="#3D6FFF"
                android:textSize="18sp"
                android:padding="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textColor="#E8EDF2"
                android:textSize="22sp"
                android:fontFamily="sans-serif-medium"/>

        </LinearLayout>

        <!-- Display section -->
        <TextView
            android:id="@+id/tv_section_display"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DISPLAY"
            android:textColor="#3D4F60"
            android:textSize="9sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="6dp"
            app:layout_constraintTop_toBottomOf="@id/ll_settings_header"
            app:layout_constraintStart_toStartOf="parent"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/card_display_settings"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#111418"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="20dp"
            app:layout_constraintTop_toBottomOf="@id/tv_section_display"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="4dp">

                <!-- Keep screen on -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Keep screen on"
                            android:textColor="#E8EDF2"
                            android:textSize="14sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Prevents sleep during run"
                            android:textColor="#3D4F60"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                    <Switch
                        android:id="@+id/sw_wake_lock"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:thumbTint="#3D6FFF"
                        android:trackTint="#1A3F6E"/>

                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#1E2530" android:layout_marginStart="12dp" android:layout_marginEnd="12dp"/>

                <!-- Update rate -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Update rate"
                            android:textColor="#E8EDF2"
                            android:textSize="14sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="How often the dashboard refreshes"
                            android:textColor="#3D4F60"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_update_rate_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="50 ms ›"
                        android:textColor="#3D6FFF"
                        android:textSize="13sp"
                        android:padding="4dp"/>

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Alerts section -->
        <TextView
            android:id="@+id/tv_section_alerts"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ALERTS"
            android:textColor="#3D4F60"
            android:textSize="9sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="6dp"
            app:layout_constraintTop_toBottomOf="@id/card_display_settings"
            app:layout_constraintStart_toStartOf="parent"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/card_alert_settings"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#111418"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="20dp"
            app:layout_constraintTop_toBottomOf="@id/tv_section_alerts"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="4dp">

                <!-- Vibrate on alert -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Vibrate on alert"
                            android:textColor="#E8EDF2"
                            android:textSize="14sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Haptic feedback for critical events"
                            android:textColor="#3D4F60"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                    <Switch
                        android:id="@+id/sw_vibrate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:thumbTint="#3D6FFF"
                        android:trackTint="#1A3F6E"/>

                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#1E2530" android:layout_marginStart="12dp" android:layout_marginEnd="12dp"/>

                <!-- Alert sound -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Alert sound"
                            android:textColor="#E8EDF2"
                            android:textSize="14sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Audio tone (off by default — helmet noise)"
                            android:textColor="#3D4F60"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                    <Switch
                        android:id="@+id/sw_alert_sound"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false"
                        android:thumbTint="#3D6FFF"
                        android:trackTint="#1A3F6E"/>

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Thresholds section -->
        <TextView
            android:id="@+id/tv_section_thresholds"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ALERT THRESHOLDS"
            android:textColor="#3D4F60"
            android:textSize="9sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="6dp"
            app:layout_constraintTop_toBottomOf="@id/card_alert_settings"
            app:layout_constraintStart_toStartOf="parent"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/card_threshold_settings"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#111418"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="28dp"
            app:layout_constraintTop_toBottomOf="@id/tv_section_thresholds"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="4dp">

                <!-- FC Temp threshold -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="FC temp limit — Thaiger 7"
                            android:textColor="#E8EDF2"
                            android:textSize="14sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Alert fires above this value"
                            android:textColor="#3D4F60"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_fc_threshold_thaiger"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="70 °C ›"
                        android:textColor="#3D6FFF"
                        android:textSize="13sp"
                        android:padding="4dp"/>

                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#1E2530" android:layout_marginStart="12dp" android:layout_marginEnd="12dp"/>

                <!-- FC Temp threshold Bengalo -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="FC temp limit — Bengalo"
                            android:textColor="#E8EDF2"
                            android:textSize="14sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Alert fires above this value"
                            android:textColor="#3D4F60"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_fc_threshold_bengalo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="70 °C ›"
                        android:textColor="#3D6FFF"
                        android:textSize="13sp"
                        android:padding="4dp"/>

                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#1E2530" android:layout_marginStart="12dp" android:layout_marginEnd="12dp"/>

                <!-- Cell-Voltage-Diff threshold Thaiger 7 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cell voltage diff limit — Thaiger 7"
                            android:textColor="#E8EDF2"
                            android:textSize="14sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cell shown red above this value"
                            android:textColor="#3D4F60"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_voltdiff_threshold_thaiger"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="50 mV ›"
                        android:textColor="#3D6FFF"
                        android:textSize="13sp"
                        android:padding="4dp"/>

                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#1E2530" android:layout_marginStart="12dp" android:layout_marginEnd="12dp"/>

                <!-- Cell-Voltage-Diff threshold Bengalo -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cell voltage diff limit — Bengalo"
                            android:textColor="#E8EDF2"
                            android:textSize="14sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cell shown red above this value"
                            android:textColor="#3D4F60"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_voltdiff_threshold_bengalo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="50 mV ›"
                        android:textColor="#3D6FFF"
                        android:textSize="13sp"
                        android:padding="4dp"/>

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Telemetry Relay section -->
        <TextView
            android:id="@+id/tv_section_relay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TELEMETRY RELAY"
            android:textColor="#3D4F60"
            android:textSize="9sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="6dp"
            app:layout_constraintTop_toBottomOf="@id/card_threshold_settings"
            app:layout_constraintStart_toStartOf="parent"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/card_relay_settings"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#111418"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="28dp"
            app:layout_constraintTop_toBottomOf="@id/tv_section_relay"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:id="@+id/row_mqtt_open"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MQTT broker"
                        android:textColor="#E8EDF2"
                        android:textSize="14sp"/>

                    <TextView
                        android:id="@+id/tv_mqtt_summary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Not configured"
                        android:textColor="#3D4F60"
                        android:textSize="11sp"
                        android:layout_marginTop="2dp"/>

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="#3D6FFF"
                    android:textSize="20sp"
                    android:padding="4dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Version footer -->
        <TextView
            android:id="@+id/tv_settings_version"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v1.0.0 · Thaiger H2 Racing · HS Stralsund"
            android:textColor="#1E2530"
            android:textSize="11sp"
            app:layout_constraintTop_toBottomOf="@id/card_relay_settings"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>